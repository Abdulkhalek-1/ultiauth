meta {
  name: Login
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/auth/password/login
  body: json
  auth: none
}

body:json {
  {
    "login": "testuser",
    "password": "SecurePass123"
  }
}

script:post-response {
  if (res.status === 200) {
    bru.setVar("accessToken", res.body.data.tokens.accessToken);
    bru.setVar("refreshToken", res.body.data.tokens.refreshToken);
  }
}
