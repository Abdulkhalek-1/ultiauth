meta {
  name: Register
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/auth/password/register
  body: json
  auth: none
}

body:json {
  {
    "username": "testuser",
    "email": "test@example.com",
    "password": "SecurePass123"
  }
}

script:post-response {
  if (res.status === 201) {
    bru.setVar("accessToken", res.body.data.tokens.accessToken);
    bru.setVar("refreshToken", res.body.data.tokens.refreshToken);
  }
}
