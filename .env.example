NODE_ENV=development
PORT=3000

# Database
DATABASE_URL=postgres://authmaster:authmaster_dev@localhost:5432/authmaster

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=change-me-in-production-use-at-least-32-characters-here
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Sessions
SESSION_SECRET=change-me-in-production-use-at-least-32-characters-here
SESSION_MAX_AGE_HOURS=24

# Google OAuth
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URL=